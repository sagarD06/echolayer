{
  "name": "echolayer",
  "private": true,
  "prisma": {
    "schema": "packages/database/prisma/schema.prisma"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "db:generate": "pnpm dlx generate",
    "db:migrate": "pnpm dlx migrate:dev",
    "db:deploy": "pnpm dlx migrate:deploy",
    "db:push": "pnpm dlx db:push",
    "db:studio": "pnpm dlx db:studio",
    "db:reset": "pnpm dlx db:reset"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "prettier": "^3.7.4",
    "turbo": "^2.8.14",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "overrides": {
      "ioredis": "5.10.0"
    }
  }
}
